---
import Layout from '../layouts/Layout.astro';

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://admin.pettrakr.io';
---

<Layout title="Contact Us" description="Get in touch with the PetTrakr team">
  <div class="min-h-screen bg-[#171D1D] py-12 px-4">
    <div class="max-w-xl mx-auto">

      <div class="mb-8">
        <h1 class="text-3xl font-bold font-['Lato',sans-serif] text-white">Contact Us</h1>
        <p class="text-white/60 mt-1">We'd love to hear from you. Send us a message and we'll get back to you as soon as possible.</p>
      </div>

      <form id="contact-form" class="space-y-5">

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-white/80 text-sm mb-1" for="firstName">First Name <span class="text-[#E14D43]">*</span></label>
            <input type="text" id="firstName" name="firstName" required
              class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
          </div>
          <div>
            <label class="block text-white/80 text-sm mb-1" for="lastName">Last Name <span class="text-[#E14D43]">*</span></label>
            <input type="text" id="lastName" name="lastName" required
              class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
          </div>
        </div>

        <div>
          <label class="block text-white/80 text-sm mb-1" for="email">Email <span class="text-[#E14D43]">*</span></label>
          <input type="email" id="email" name="email" required
            class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
        </div>

        <div>
          <label class="block text-white/80 text-sm mb-1" for="subject">Subject <span class="text-[#E14D43]">*</span></label>
          <input type="text" id="subject" name="subject" required
            class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
        </div>

        <div>
          <label class="block text-white/80 text-sm mb-1" for="message">Message <span class="text-[#E14D43]">*</span></label>
          <textarea id="message" name="message" rows="5" required
            class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]"></textarea>
        </div>

        <p id="form-error" class="hidden text-[#E14D43] text-sm"></p>

        <button type="submit" id="submit-btn"
          class="w-full bg-[#E14D43] hover:bg-[#494578] text-white font-bold py-3 rounded transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
          Send Message
        </button>

      </form>

      <div id="success-message" class="hidden text-center py-12">
        <div class="text-5xl mb-4">✓</div>
        <h2 class="text-2xl font-bold text-white mb-2">Message Sent</h2>
        <p class="text-white/60">Thanks for getting in touch. We'll get back to you shortly.</p>
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ DIRECTUS_URL }}>
  document.getElementById('contact-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const errorEl = document.getElementById('form-error');
    btn.disabled = true;
    btn.textContent = 'Sending…';
    errorEl.classList.add('hidden');

    const form = e.target;
    const payload = {
      firstName: form.firstName.value,
      lastName: form.lastName.value,
      email: form.email.value,
      subject: form.subject.value,
      message: form.message.value,
    };

    try {
      const res = await fetch(`${DIRECTUS_URL}/flows/trigger/contact-form`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      document.getElementById('contact-form').classList.add('hidden');
      document.getElementById('success-message').classList.remove('hidden');
    } catch (err) {
      errorEl.textContent = 'Something went wrong. Please try again or email us directly at hello@pettrakr.com.au';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
