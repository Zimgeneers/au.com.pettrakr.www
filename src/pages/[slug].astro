---
import Layout from '../layouts/Layout.astro';
import SectionRenderer from '../components/sections/SectionRenderer.astro';
import { getPageBySlug, getSectionsByPage, fileUrl } from '../lib/directus';

export async function getStaticPaths() {
  const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://admin.pettrakr.io';
  const res = await fetch(`${DIRECTUS_URL}/items/pages?fields=slug&filter[slug][_neq]=home`);
  const json = await res.json();
  return (json.data as { slug: string }[]).map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const page = await getPageBySlug(slug);
const sections = page ? await getSectionsByPage(page.id) : [];
const heroImageUrl = page ? fileUrl(page.heroImage) : null;
---

<Layout
  title={page?.seoTitle || page?.title}
  description={page?.seoDescription}
  ogImage={page ? fileUrl(page.seoImage) : null}
>

  <!-- Hero -->
  {page.heroHeading && (
    <section
      class="relative min-h-[40vh] flex items-center justify-center text-white text-center"
      style={heroImageUrl
        ? `background-image: url('${heroImageUrl}'); background-size: cover; background-position: center;`
        : 'background-color: #171D1D;'}
    >
      <div class="absolute inset-0 bg-black/50"></div>
      <div class="relative z-10 max-w-3xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold font-['Lato',sans-serif] mb-4 leading-tight">
          {page.heroHeading}
        </h1>
        {page.heroSubheading && (
          <p class="text-lg text-white/80">{page.heroSubheading}</p>
        )}
        {page.heroCtaText && (
          <a
            href={page.heroCtaUrl || '/book'}
            class="inline-block mt-6 bg-[#E14D43] hover:bg-[#494578] text-white font-bold px-8 py-3 rounded transition-colors text-lg"
          >
            {page.heroCtaText}
          </a>
        )}
      </div>
    </section>
  )}

  <!-- Dynamic sections -->
  {sections.map(section => <SectionRenderer section={section} />)}

</Layout>
