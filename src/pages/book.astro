---
import Layout from '../layouts/Layout.astro';

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://admin.pettrakr.io';

// Fetch airports for dropdowns
const airportsRes = await fetch(`${DIRECTUS_URL}/items/airports?fields=id,iataCode,name,city,country&sort=name&limit=500`);
const airportsJson = await airportsRes.json();
const airports = (airportsJson.data as { id: number; iataCode: string; name: string; city: string; country: string }[])
  .filter(a => a.iataCode);
---

<Layout title="Book" description="Reserve your PetTrakr device">
  <div id="form-root" class="min-h-screen bg-[#171D1D] py-12 px-4">
    <div class="max-w-3xl mx-auto">

      <!-- Invalid token -->
      <div id="invalid-token" class="hidden text-center py-16">
        <p class="text-white text-xl font-bold mb-2">Invalid booking link</p>
        <p class="text-white/60">Please contact your pet travel company for a valid booking link.</p>
      </div>

      <!-- Form -->
      <div id="form-container" class="hidden">

        <!-- Header: logo + title side by side -->
        <div class="flex items-center gap-6 mb-8">
          <img id="company-logo" src="" alt="" class="hidden h-24 w-auto object-contain flex-shrink-0" />
          <div>
            <h1 class="text-3xl font-bold font-['Lato',sans-serif] text-white">Reserve a Trip</h1>
            <p class="text-white/60 mt-1">Note that if you cannot provide the Tag or Device details now you will need to email these to us at least 24 hours prior to the trip: <a href="mailto:hello@pettrakr.com.au" class="text-[#ffc803] hover:underline">hello@pettrakr.com.au</a></p>
          </div>
        </div>

        <form id="booking-form" class="space-y-8">
          <input type="hidden" id="company-id" name="companyId" value="" />

          <!-- Pet Owner -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Customer Details</legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-white/80 text-sm mb-1" for="firstName">First Name <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="firstName" name="firstName" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="lastName">Last Name <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="lastName" name="lastName" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="email">Email <span class="text-[#E14D43]">*</span></label>
                <input type="email" id="email" name="email" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="phone">Phone <span class="text-[#E14D43]">*</span></label>
                <input type="tel" id="phone" name="phone" required placeholder="+61 400 000 000"
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
            </div>
          </fieldset>

          <!-- Pet -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Pet Details</legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-white/80 text-sm mb-1" for="petName">Pet Name <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="petName" name="petName" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="petBreed">Breed <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="petBreed" name="petBreed" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div class="sm:col-span-2">
                <label class="block text-white/80 text-sm mb-1" for="companyReference">Your Booking Reference <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="companyReference" name="companyReference" required placeholder="Your company's booking reference number"
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
            </div>
          </fieldset>

          <!-- Flights -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Flight Details</legend>
            <div id="flights-list" class="space-y-6"></div>
            <button type="button" id="add-flight"
              class="mt-4 text-sm text-[#ffc803] hover:text-white border border-[#ffc803]/40 hover:border-[#ffc803] rounded px-4 py-2 transition-colors">
              + Add Flight
            </button>
          </fieldset>

          <!-- Services -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Services Required <span class="text-[#E14D43]">*</span></legend>
            <div class="flex flex-col gap-4">
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" id="serviceDevice" name="serviceDevice" value="device"
                  class="w-4 h-4 accent-[#E14D43]" />
                <span class="text-white">Add a PetTrakr Device</span>
              </label>
              <div>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" id="serviceTag" name="serviceTag" value="tag"
                    class="w-4 h-4 accent-[#E14D43]" />
                  <span class="text-white">Add a TrakrTag</span>
                </label>
                <div id="tag-select-container" class="hidden mt-3 ml-7">
                  <label class="block text-white/80 text-sm mb-1" for="tagId">Select Tag</label>
                  <select id="tagId" name="tagId"
                    class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white focus:outline-none focus:border-[#ffc803]">
                    <option value="" class="bg-[#171D1D]">— select a tag —</option>
                  </select>
                  <p class="text-white/30 text-xs mt-1">Only available tags assigned to your company are shown. If none are listed, leave blank and email us the tag details.</p>
                </div>
              </div>
            </div>
          </fieldset>

          <!-- Notes -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Additional Information</legend>
            <textarea id="notes" name="notes" rows="3" placeholder="Any special requirements or information..."
              class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]"></textarea>
          </fieldset>

          <!-- Error message -->
          <p id="form-error" class="hidden text-[#E14D43] text-sm text-center"></p>

          <!-- Submit -->
          <div class="text-center">
            <button type="submit" id="submit-btn"
              class="bg-[#E14D43] hover:bg-[#494578] text-white font-bold px-10 py-3 rounded transition-colors text-lg disabled:opacity-50 disabled:cursor-not-allowed">
              Submit Reservation Request
            </button>
          </div>
        </form>

        <!-- Success -->
        <div id="success-message" class="hidden py-12 max-w-xl mx-auto">
          <div class="text-5xl mb-4 text-center">✓</div>
          <h2 class="text-2xl font-bold text-white mb-6 text-center">Booking Received</h2>
          <div class="space-y-3 text-white/70 text-sm leading-relaxed">
            <p>If you have requested a <strong class="text-white">PetTrakr Device</strong> we will be in touch to confirm which device to use and provide further instructions.</p>
            <p>If you have assigned a <strong class="text-white">TrakrTag</strong> please set the tag aside and ensure that it is <strong class="text-white">ONLY</strong> used for this trip.</p>
            <p>If you have <strong class="text-white">not</strong> assigned a TrakrTag yet please email us the details at least <strong class="text-white">48 hours prior to departure</strong>.</p>
            <p>If you need more TrakrTags please email us.</p>
          </div>
          <div class="mt-6 text-center">
            <a href="mailto:hello@pettrakr.com.au" class="text-[#ffc803] hover:underline text-sm">hello@pettrakr.com.au</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ airports, DIRECTUS_URL }}>
  // ── Airport combobox ─────────────────────────────────────────
  const airportSelect = (name, label) => `
    <div class="relative airport-combobox" data-name="${name}">
      <label class="block text-white/80 text-sm mb-1">${label} <span class="text-red-400">*</span></label>
      <input type="text" autocomplete="off" placeholder="Type to search..."
        class="combobox-input w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-yellow-400" />
      <input type="hidden" name="${name}" class="combobox-value" required />
      <ul class="combobox-list hidden absolute z-50 w-full mt-1 bg-[#1e2424] border border-white/20 rounded max-h-48 overflow-y-auto shadow-xl"></ul>
    </div>`;

  // ── Flight template ──────────────────────────────────────────
  let flightCount = 0;

  function addFlight() {
    flightCount++;
    const idx = flightCount;
    const div = document.createElement('div');
    div.className = 'bg-white/5 border border-white/10 rounded-lg p-4 relative';
    div.dataset.flight = idx;
    div.innerHTML = `
      <div class="flex justify-between items-center mb-3">
        <span class="text-white/60 text-sm font-bold">Flight ${idx}</span>
        ${idx > 1 ? `<button type="button" onclick="removeFlight(${idx})" class="text-white/30 hover:text-red-400 text-sm transition-colors">Remove</button>` : ''}
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-white/80 text-sm mb-1">Flight Number <span class="text-red-400">*</span></label>
          <input type="text" name="flightNumber_${idx}" required placeholder="EK407"
            pattern="[A-Z]{2}[0-9]{1,4}"
            title="Two uppercase letters followed by 1-4 digits (e.g. EK407)"
            class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-yellow-400 uppercase"
            oninput="this.value = this.value.toUpperCase()" />
          <p class="text-white/30 text-xs mt-1">e.g. EK407, NZ1</p>
        </div>
        <div>
          <label class="block text-white/80 text-sm mb-1">Flight Date <span class="text-red-400">*</span></label>
          <input type="date" name="flightDate_${idx}" required
            min="${new Date().toISOString().split('T')[0]}"
            class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white focus:outline-none focus:border-yellow-400" />
        </div>
        ${airportSelect(`depAirport_${idx}`, 'Departure Airport')}
        ${airportSelect(`arrAirport_${idx}`, 'Arrival Airport')}
      </div>`;
    document.getElementById('flights-list').appendChild(div);
  }

  window.removeFlight = (idx) => {
    document.querySelector(`[data-flight="${idx}"]`)?.remove();
  };

  // ── Combobox logic ───────────────────────────────────────────
  function initComboboxes(container) {
    container.querySelectorAll('.airport-combobox').forEach(box => {
      const input = box.querySelector('.combobox-input');
      const hidden = box.querySelector('.combobox-value');
      const list = box.querySelector('.combobox-list');

      input.addEventListener('input', () => {
        const q = input.value.toLowerCase();
        hidden.value = '';
        if (!q) { list.classList.add('hidden'); return; }

        const matches = airports.filter(a =>
          a.iataCode.toLowerCase().includes(q) ||
          a.name.toLowerCase().includes(q) ||
          a.city.toLowerCase().includes(q)
        ).slice(0, 20);

        list.innerHTML = matches.length
          ? matches.map(a =>
              `<li data-code="${a.iataCode}" class="px-3 py-2 text-sm text-white cursor-pointer hover:bg-white/10">
                <span class="font-bold">${a.iataCode}</span> — ${a.name}, ${a.city}
              </li>`).join('')
          : `<li class="px-3 py-2 text-sm text-white/40">No airports found</li>`;

        list.classList.remove('hidden');
      });

      list.addEventListener('click', e => {
        const li = e.target.closest('li[data-code]');
        if (!li) return;
        const code = li.dataset.code;
        const airport = airports.find(a => a.iataCode === code);
        input.value = `${airport.iataCode} — ${airport.name}, ${airport.city}`;
        hidden.value = airport.id;
        list.classList.add('hidden');
      });

      document.addEventListener('click', e => {
        if (!box.contains(e.target)) list.classList.add('hidden');
      });
    });
  }

  function addFlight_withCombobox() {
    addFlight();
    const flightEl = document.querySelector(`[data-flight="${flightCount}"]`);
    if (flightEl) initComboboxes(flightEl);
  }

  document.getElementById('add-flight').addEventListener('click', addFlight_withCombobox);

  // Add first flight on load
  addFlight();
  const firstFlight = document.querySelector('[data-flight="1"]');
  if (firstFlight) initComboboxes(firstFlight);

  // ── Token lookup ─────────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');

  async function loadCompany() {
    if (!token) {
      document.getElementById('invalid-token').classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch(
        `${DIRECTUS_URL}/items/pet_travel_companies?filter[bookingToken][_eq]=${token}&fields=id,name,logo&limit=1`
      );
      const json = await res.json();
      const company = json.data?.[0];

      if (!company) {
        document.getElementById('invalid-token').classList.remove('hidden');
        return;
      }

      // Set hidden company ID
      document.getElementById('company-id').value = company.id;

      // Show company logo
      if (company.logo) {
        const logoEl = document.getElementById('company-logo');
        logoEl.src = `${DIRECTUS_URL}/assets/${company.logo}`;
        logoEl.alt = company.name;
        logoEl.classList.remove('hidden');
      }

      document.getElementById('form-container').classList.remove('hidden');

      // Load available tags for this company
      const tagsRes = await fetch(
        `${DIRECTUS_URL}/items/tags?filter[petTravelCompany][_eq]=${company.id}&filter[status][_eq]=available&fields=id,tagId,tagType&sort=tagId`
      );
      const tagsJson = await tagsRes.json();
      const tags = tagsJson.data ?? [];
      const tagSelect = document.getElementById('tagId');
      tags.forEach(tag => {
        const opt = document.createElement('option');
        opt.value = tag.id;
        opt.textContent = tag.tagType ? `${tag.tagId} (${tag.tagType})` : tag.tagId;
        opt.className = 'bg-[#171D1D]';
        tagSelect.appendChild(opt);
      });

    } catch (e) {
      document.getElementById('invalid-token').classList.remove('hidden');
    }
  }

  loadCompany();

  // ── Tag select toggle ────────────────────────────────────────
  document.getElementById('serviceTag').addEventListener('change', function() {
    const container = document.getElementById('tag-select-container');
    container.classList.toggle('hidden', !this.checked);
  });

  // ── Helpers ──────────────────────────────────────────────────
  async function findOrCreate(collection, filter, createPayload) {
    const params = Object.entries(filter)
      .map(([k, v]) => `filter[${k}][_eq]=${encodeURIComponent(v)}`)
      .join('&');
    const findRes = await fetch(`${DIRECTUS_URL}/items/${collection}?${params}&fields=id&limit=1`);
    const found = (await findRes.json()).data?.[0];
    if (found) return found.id;
    const createRes = await fetch(`${DIRECTUS_URL}/items/${collection}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(createPayload),
    });
    if (!createRes.ok) throw new Error(`Failed to create ${collection}: HTTP ${createRes.status}`);
    return (await createRes.json()).data?.id;
  }

  async function findOrCreateFlight(flightNumber, flightDate, depAirport, arrAirport) {
    const params = [
      `filter[flightNumber][_eq]=${encodeURIComponent(flightNumber)}`,
      `filter[startDateTime][_between][]=${encodeURIComponent(flightDate + 'T00:00:00')}`,
      `filter[startDateTime][_between][]=${encodeURIComponent(flightDate + 'T23:59:59')}`,
      `filter[departureAirport][_eq]=${encodeURIComponent(depAirport)}`,
      `filter[destinationAirport][_eq]=${encodeURIComponent(arrAirport)}`,
      'fields=id',
      'limit=1',
    ].join('&');
    const findRes = await fetch(`${DIRECTUS_URL}/items/flights?${params}`);
    const found = (await findRes.json()).data?.[0];
    if (found) return found.id;
    const createRes = await fetch(`${DIRECTUS_URL}/items/flights`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        flightNumber,
        startDateTime: flightDate + 'T00:00:00',
        departureAirport: Number(depAirport),
        destinationAirport: Number(arrAirport),
      }),
    });
    if (!createRes.ok) throw new Error(`Failed to create flight: HTTP ${createRes.status}`);
    return (await createRes.json()).data?.id;
  }

  // ── Form submission ──────────────────────────────────────────
  document.getElementById('booking-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const errorEl = document.getElementById('form-error');
    btn.disabled = true;
    btn.textContent = 'Submitting…';
    errorEl.classList.add('hidden');

    const form = e.target;
    const email = form.email.value;
    const petName = form.petName.value;

    try {
      // ── Find or create customer (dedup by email) ─────────────
      btn.textContent = 'Looking up customer…';
      const customerId = await findOrCreate(
        'customers',
        { email },
        {
          firstName: form.firstName.value,
          lastName: form.lastName.value,
          email,
          phone: form.phone.value,
        }
      );

      // ── Find or create pet (dedup by name + customer) ────────
      btn.textContent = 'Looking up pet…';
      const petId = await findOrCreate(
        'pets',
        { name: petName, customer: customerId },
        { name: petName, type: form.petBreed.value, customer: customerId }
      );

      // ── Check reference uniqueness ───────────────────────────
      btn.textContent = 'Checking reference…';
      const companyId = document.getElementById('company-id').value;
      const reference = form.companyReference.value.trim();
      const refCheck = await fetch(
        `${DIRECTUS_URL}/items/trips?filter[reference][_eq]=${encodeURIComponent(reference)}&fields=id&limit=1`
      );
      const refExists = (await refCheck.json()).data?.length > 0;
      if (refExists) {
        throw new Object({ userMessage: 'This booking reference has already been submitted. Please check your reference number or contact us if you believe this is an error.' });
      }

      // ── Collect and dedup flights ────────────────────────────
      btn.textContent = 'Processing flights…';
      const flightIds = [];
      for (const el of document.querySelectorAll('[data-flight]')) {
        const idx = el.dataset.flight;
        const flightNumber = el.querySelector(`[name="flightNumber_${idx}"]`).value;
        const flightDate = el.querySelector(`[name="flightDate_${idx}"]`).value;
        const depAirport = el.querySelector(`[name="depAirport_${idx}"]`).value;
        const arrAirport = el.querySelector(`[name="arrAirport_${idx}"]`).value;
        const flightId = await findOrCreateFlight(flightNumber, flightDate, depAirport, arrAirport);
        flightIds.push(flightId);
      }

      // ── Submit to flow ───────────────────────────────────────
      btn.textContent = 'Creating trip…';
      const payload = {
        petId,
        customerId,
        companyId,
        companyReference: reference,
        email,
        firstName: form.firstName.value,
        lastName: form.lastName.value,
        phone: form.phone.value,
        petName,
        petBreed: form.petBreed.value,
        servicesRequested: [
          form.serviceDevice.checked ? 'device' : null,
          form.serviceTag.checked ? 'tag' : null,
        ].filter(Boolean),
        tagId: form.serviceTag.checked && form.tagId.value ? Number(form.tagId.value) : null,
        notes: form.notes.value,
        flightIds,
      };

      const res = await fetch(`${DIRECTUS_URL}/flows/trigger/d6d1613b-70d5-49df-a3bd-c97e87579f95`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      document.getElementById('booking-form').classList.add('hidden');
      document.getElementById('success-message').classList.remove('hidden');
    } catch (err) {
      errorEl.textContent = err?.userMessage ?? 'Something went wrong. Please try again or contact us directly.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Submit Reservation Request';
    }
  });
</script>
