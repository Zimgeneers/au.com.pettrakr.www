---
import Layout from '../layouts/Layout.astro';

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL ?? 'https://admin.pettrakr.io';
const AERODATABOX_KEY = import.meta.env.PUBLIC_AERODATABOX_KEY ?? '';

// Fetch airports (IATA → Directus ID + timezone, used to match AeroDataBox response)
const airportsRes = await fetch(`${DIRECTUS_URL}/items/airports?fields=id,iataCode,name,city,timezone&sort=name&limit=500`);
const airportsJson = await airportsRes.json();
const airports = (airportsJson.data as { id: number; iataCode: string; name: string; city: string; timezone: string }[])
  .filter(a => a.iataCode);
---

<Layout title="Book" description="Reserve your PetTrakr device">
  <div id="form-root" class="min-h-screen bg-[#171D1D] py-12 px-4">
    <div class="max-w-3xl mx-auto">

      <!-- Invalid token -->
      <div id="invalid-token" class="hidden text-center py-16">
        <p class="text-white text-xl font-bold mb-2">Invalid booking link</p>
        <p class="text-white/60">Please contact your pet travel company for a valid booking link.</p>
      </div>

      <!-- Form -->
      <div id="form-container" class="hidden">

        <!-- Header: logo + title side by side -->
        <div class="flex items-center gap-6 mb-8">
          <img id="company-logo" src="" alt="" class="hidden h-24 w-auto object-contain flex-shrink-0" />
          <div>
            <h1 class="text-3xl font-bold font-['Lato',sans-serif] text-white">Reserve a Trip</h1>
            <p class="text-white/60 mt-1">Note that if you cannot provide the Tag or Device details now you will need to email these to us at least 24 hours prior to the trip: <a href="mailto:hello@pettrakr.com.au" class="text-[#ffc803] hover:underline">hello@pettrakr.com.au</a></p>
          </div>
        </div>

        <form id="booking-form" class="space-y-8">
          <input type="hidden" id="company-id" name="companyId" value="" />

          <!-- Trip Details -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Trip Details</legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="sm:col-span-2">
                <label class="block text-white/80 text-sm mb-1" for="companyReference">Booking Reference <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="companyReference" name="companyReference" required placeholder="Your company's booking reference number"
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="contactName">Agent Name <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="contactName" name="contactName" required placeholder="Your name"
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="contactEmail">Agent Email <span class="text-[#E14D43]">*</span></label>
                <input type="email" id="contactEmail" name="contactEmail" required placeholder="Your email"
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
            </div>
          </fieldset>

          <!-- Pet Owner -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Customer Details</legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-white/80 text-sm mb-1" for="firstName">First Name <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="firstName" name="firstName" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="lastName">Last Name <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="lastName" name="lastName" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="email">Email <span class="text-[#E14D43]">*</span></label>
                <input type="email" id="email" name="email" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" placeholder="+61 400 000 000"
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
            </div>
          </fieldset>

          <!-- Pet -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Pet Details</legend>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-white/80 text-sm mb-1" for="petName">Pet Name <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="petName" name="petName" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
              <div>
                <label class="block text-white/80 text-sm mb-1" for="petBreed">Breed <span class="text-[#E14D43]">*</span></label>
                <input type="text" id="petBreed" name="petBreed" required
                  class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]" />
              </div>
            </div>
          </fieldset>

          <!-- Flights -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Flight Details</legend>

            <!-- Confirmed flights list -->
            <div id="confirmed-flights-list" class="space-y-2 mb-4"></div>
            <p id="flights-required" class="hidden text-[#E14D43] text-xs mb-3">Please add at least one flight.</p>

            <!-- Add a Flight panel -->
            <div class="bg-white/5 border border-white/10 rounded-lg p-4">
              <p class="text-white font-bold text-sm mb-4">Add a Flight</p>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                  <label class="block text-white/80 text-sm mb-1">Flight Number</label>
                  <input type="text" id="lookup-flight-number" placeholder="EK407"
                    class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803] uppercase"
                    oninput="this.value = this.value.toUpperCase()" />
                  <p class="text-white/30 text-xs mt-1">e.g. EK407, QR901</p>
                </div>
                <div>
                  <label class="block text-white/80 text-sm mb-1">Flight Date</label>
                  <input type="date" id="lookup-flight-date"
                    class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white focus:outline-none focus:border-[#ffc803]" />
                </div>
              </div>
              <div class="mt-3">
                <button type="button" id="lookup-btn"
                  class="text-sm text-[#ffc803] hover:text-white border border-[#ffc803]/40 hover:border-[#ffc803] rounded px-4 py-2 transition-colors disabled:opacity-40 disabled:cursor-not-allowed">
                  Look Up Flight
                </button>
              </div>
              <p id="lookup-error" class="hidden text-[#E14D43] text-xs mt-2"></p>

              <!-- Preview area -->
              <div id="preview-area"></div>

              <!-- Flash confirmation -->
              <div id="flight-added-flash" class="hidden mt-3 text-sm text-emerald-400 font-medium">Flight Added. Enter another Flight number above or continue to next section.</div>
            </div>
          </fieldset>

          <!-- Services -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Services Required <span class="text-[#E14D43]">*</span></legend>
            <div class="flex flex-col gap-4">
              <label class="flex items-center gap-3 cursor-pointer">
                <input type="checkbox" id="serviceDevice" name="serviceDevice" value="device"
                  class="w-4 h-4 accent-[#E14D43]" />
                <span class="text-white">Add a PetTrakr Device</span>
              </label>
              <div>
                <label class="flex items-center gap-3 cursor-pointer">
                  <input type="checkbox" id="serviceTag" name="serviceTag" value="tag"
                    class="w-4 h-4 accent-[#E14D43]" />
                  <span class="text-white">Add a TrakrTag</span>
                </label>
                <div id="tag-select-container" class="hidden mt-3 ml-7">
                  <label class="block text-white/80 text-sm mb-1" for="tagId">Select Tag</label>
                  <select id="tagId" name="tagId"
                    class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white focus:outline-none focus:border-[#ffc803]">
                    <option value="" class="bg-[#171D1D]">— select a tag —</option>
                  </select>
                  <p class="text-white/30 text-xs mt-1">Only available tags assigned to your company are shown. If none are listed, leave blank and email us the tag details.</p>
                </div>
              </div>
            </div>
          </fieldset>

          <!-- Notes -->
          <fieldset>
            <legend class="text-[#ffc803] font-bold text-sm uppercase tracking-wider mb-4">Additional Information</legend>
            <textarea id="notes" name="notes" rows="3" placeholder="Any special requirements or information..."
              class="w-full bg-white/10 border border-white/20 rounded px-3 py-2 text-white placeholder-white/30 focus:outline-none focus:border-[#ffc803]"></textarea>
          </fieldset>

          <!-- Error message -->
          <p id="form-error" class="hidden text-[#E14D43] text-sm text-center"></p>

          <!-- Submit -->
          <div class="text-center">
            <button type="submit" id="submit-btn"
              class="bg-[#E14D43] hover:bg-[#494578] text-white font-bold px-10 py-3 rounded transition-colors text-lg disabled:opacity-50 disabled:cursor-not-allowed">
              Submit Reservation Request
            </button>
          </div>
        </form>

        <!-- Success -->
        <div id="success-message" class="hidden py-12 max-w-xl mx-auto">
          <div class="text-5xl mb-4 text-center">✓</div>
          <h2 class="text-2xl font-bold text-white mb-6 text-center">Booking Received</h2>
          <div class="space-y-3 text-white/70 text-sm leading-relaxed">
            <p>If you have requested a <strong class="text-white">PetTrakr Device</strong> we will be in touch to confirm which device to use and provide further instructions.</p>
            <p>If you have assigned a <strong class="text-white">TrakrTag</strong> please set the tag aside and ensure that it is <strong class="text-white">ONLY</strong> used for this trip.</p>
            <p>If you have <strong class="text-white">not</strong> assigned a TrakrTag yet please email us the details at least <strong class="text-white">48 hours prior to departure</strong>.</p>
            <p>If you need more TrakrTags please email us.</p>
          </div>
          <div class="mt-6 text-center">
            <a href="mailto:hello@pettrakr.com.au" class="text-[#ffc803] hover:underline text-sm">hello@pettrakr.com.au</a>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script define:vars={{ airports, DIRECTUS_URL, AERODATABOX_KEY }}>
  const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];

  // Airports keyed by IATA code for fast lookup
  const airportByIata = {};
  airports.forEach(a => { airportByIata[a.iataCode] = a; });

  // Confirmed flights accumulator: array of objects with all fields needed for Directus
  const confirmedFlights = [];

  // ── AeroDataBox lookup ───────────────────────────────────────
  async function lookupFlight(flightNumber, isoDate) {
    // AeroDataBox expects date as YYYY-MM-DD
    const url = `https://aerodatabox.p.rapidapi.com/flights/number/${encodeURIComponent(flightNumber)}/${isoDate}?withAircraftImage=false&withLocation=false`;
    const res = await fetch(url, {
      headers: {
        'x-rapidapi-host': 'aerodatabox.p.rapidapi.com',
        'x-rapidapi-key': AERODATABOX_KEY,
      },
    });
    if (res.status === 404) return null;
    if (!res.ok) throw new Error(`AeroDataBox error: HTTP ${res.status}`);
    const data = await res.json();
    // Returns array; pick first non-codeshare or just first result
    const results = Array.isArray(data) ? data : [data];
    return results[0] ?? null;
  }

  // ── Format local datetime string from AeroDataBox ────────────
  // AeroDataBox returns e.g. "2026-03-23T22:45:00" — use as-is
  function parseLocalDT(dt) {
    if (!dt) return null;
    return typeof dt === 'object' ? dt.local ?? dt.utc ?? null : dt;
  }

  // ── Render preview card ──────────────────────────────────────
  function renderPreview(flight, rawNumber, isoDate) {
    const dep = flight.departure;
    const arr = flight.arrival;
    const depIata = dep?.airport?.iata ?? '???';
    const arrIata = arr?.airport?.iata ?? '???';
    const depAirport = airportByIata[depIata];
    const arrAirport = airportByIata[arrIata];
    const airlineName = flight.airline?.name ?? rawNumber.match(/^[A-Z]{2}/)?.[0] ?? '';
    const depCity = depAirport?.city ?? dep?.airport?.name ?? depIata;
    const arrCity = arrAirport?.city ?? arr?.airport?.name ?? arrIata;
    const depLocalDT = parseLocalDT(dep?.scheduledTime);
    const arrLocalDT = parseLocalDT(arr?.scheduledTime);
    const depTZ = depAirport?.timezone ?? '';
    const arrTZ = arrAirport?.timezone ?? '';

    // Format display times
    function fmtDT(dtStr) {
      if (!dtStr) return '—';
      const d = new Date(dtStr);
      return `${String(d.getDate()).padStart(2,'0')} ${MONTHS[d.getMonth()]} ${d.getFullYear()} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
    }

    // Build qualified flight number: EK407/23MAR
    const dateObj = new Date(isoDate);
    const qualified = `${rawNumber}/${String(dateObj.getUTCDate()).padStart(2,'0')}${MONTHS[dateObj.getUTCMonth()]}`;

    const unknownDep = !depAirport;
    const unknownArr = !arrAirport;
    const warning = (unknownDep || unknownArr)
      ? `<p class="text-[#E14D43] text-xs mt-3">${[
          unknownDep ? `Departure airport ${depIata} is not in our database` : '',
          unknownArr ? `Arrival airport ${arrIata} is not in our database` : '',
        ].filter(Boolean).join(' · ')} — contact us if this looks wrong.</p>`
      : '';

    const previewData = {
      qualified,
      rawNumber,
      depIata, arrIata,
      depAirportId: depAirport?.id ?? null,
      arrAirportId: arrAirport?.id ?? null,
      depCity, arrCity,
      depLocalDT, arrLocalDT,
      depTZ, arrTZ,
      airlineName,
    };

    document.getElementById('preview-area').innerHTML = `
      <div id="preview-card" class="mt-4 bg-white/5 border border-[#ffc803]/40 rounded-lg p-4">
        <div class="flex justify-between items-start mb-3">
          <div>
            <span class="text-white font-bold">${qualified}</span>
            <span class="text-white/50 text-sm ml-2">${airlineName}</span>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <p class="text-white/40 text-xs uppercase tracking-wide mb-1">Departure</p>
            <p class="text-white font-bold">${depIata}</p>
            <p class="text-white/70">${depCity}</p>
            <p class="text-white/50 text-xs mt-1">${fmtDT(depLocalDT)}</p>
            <p class="text-white/30 text-xs">${depTZ}</p>
          </div>
          <div>
            <p class="text-white/40 text-xs uppercase tracking-wide mb-1">Arrival</p>
            <p class="text-white font-bold">${arrIata}</p>
            <p class="text-white/70">${arrCity}</p>
            <p class="text-white/50 text-xs mt-1">${fmtDT(arrLocalDT)}</p>
            <p class="text-white/30 text-xs">${arrTZ}</p>
          </div>
        </div>
        ${warning}
        <div class="flex gap-3 mt-4">
          <button type="button" id="confirm-flight-btn"
            class="text-sm bg-[#ffc803] hover:bg-[#ffc803]/80 text-black font-bold px-4 py-2 rounded transition-colors">
            Add Flight
          </button>
          <button type="button" id="cancel-flight-btn"
            class="text-sm text-white/40 hover:text-white border border-white/20 hover:border-white/60 px-4 py-2 rounded transition-colors">
            Try Again
          </button>
        </div>
      </div>`;

    document.getElementById('confirm-flight-btn').addEventListener('click', () => confirmFlight(previewData));
    document.getElementById('cancel-flight-btn').addEventListener('click', cancelPreview);
  }

  function cancelPreview() {
    document.getElementById('preview-area').innerHTML = '';
    document.getElementById('lookup-flight-number').value = '';
    document.getElementById('lookup-flight-date').value = '';
    document.getElementById('lookup-flight-number').focus();
  }

  function confirmFlight(data) {
    confirmedFlights.push(data);
    document.getElementById('preview-area').innerHTML = '';
    document.getElementById('lookup-flight-number').value = '';
    document.getElementById('lookup-flight-date').value = '';
    document.getElementById('lookup-error').classList.add('hidden');
    document.getElementById('flights-required').classList.add('hidden');
    renderConfirmedList();

    // Flash confirmation
    const flash = document.getElementById('flight-added-flash');
    flash.classList.remove('hidden');
    setTimeout(() => flash.classList.add('hidden'), 4000);

    document.getElementById('lookup-flight-number').focus();
  }

  // ── Confirmed flights list ───────────────────────────────────
  function renderConfirmedList() {
    const list = document.getElementById('confirmed-flights-list');
    if (confirmedFlights.length === 0) { list.innerHTML = ''; return; }
    list.innerHTML = confirmedFlights.map((f, i) => `
      <div class="flex items-center justify-between bg-white/5 border border-white/10 rounded px-4 py-3 text-sm">
        <div>
          <span class="text-white font-bold">${f.qualified}</span>
          <span class="text-white/50 ml-2">${f.depIata} → ${f.arrIata}</span>
          <span class="text-white/30 ml-2">${f.airlineName}</span>
        </div>
        <button type="button" onclick="removeConfirmedFlight(${i})"
          class="text-white/30 hover:text-[#E14D43] text-xs transition-colors ml-4">Remove</button>
      </div>`).join('');
  }

  window.removeConfirmedFlight = (i) => {
    confirmedFlights.splice(i, 1);
    renderConfirmedList();
  };

  // ── Lookup button ────────────────────────────────────────────
  document.getElementById('lookup-btn').addEventListener('click', async () => {
    const numInput = document.getElementById('lookup-flight-number');
    const dateInput = document.getElementById('lookup-flight-date');
    const errorEl = document.getElementById('lookup-error');
    const btn = document.getElementById('lookup-btn');

    const flightNumber = numInput.value.trim().toUpperCase();
    const flightDate = dateInput.value;

    errorEl.classList.add('hidden');

    if (!flightNumber || !flightDate) {
      errorEl.textContent = 'Please enter a flight number and date.';
      errorEl.classList.remove('hidden');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Looking up…';
    document.getElementById('preview-area').innerHTML = '';

    try {
      const flight = await lookupFlight(flightNumber, flightDate);
      if (!flight) {
        errorEl.textContent = `Flight ${flightNumber} not found for ${flightDate}. Check the number and date and try again.`;
        errorEl.classList.remove('hidden');
      } else {
        renderPreview(flight, flightNumber, flightDate);
      }
    } catch (err) {
      errorEl.textContent = 'Could not look up flight. Please try again.';
      errorEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Look Up Flight';
    }
  });

  // ── Token lookup ─────────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const token = params.get('token');

  async function loadCompany() {
    if (!token) {
      document.getElementById('invalid-token').classList.remove('hidden');
      return;
    }

    try {
      const res = await fetch(
        `${DIRECTUS_URL}/items/pet_travel_companies?filter[bookingToken][_eq]=${token}&fields=id,name,logo&limit=1`
      );
      const json = await res.json();
      const company = json.data?.[0];

      if (!company) {
        document.getElementById('invalid-token').classList.remove('hidden');
        return;
      }

      document.getElementById('company-id').value = company.id;

      if (company.logo) {
        const logoEl = document.getElementById('company-logo');
        logoEl.src = `${DIRECTUS_URL}/assets/${company.logo}`;
        logoEl.alt = company.name;
        logoEl.classList.remove('hidden');
      }

      document.getElementById('form-container').classList.remove('hidden');

      const tagsRes = await fetch(
        `${DIRECTUS_URL}/items/tags?filter[petTravelCompany][_eq]=${company.id}&filter[status][_eq]=available&fields=id,tagId,tagType&sort=tagId`
      );
      const tagsJson = await tagsRes.json();
      const tags = tagsJson.data ?? [];
      const tagSelect = document.getElementById('tagId');
      tags.forEach(tag => {
        const opt = document.createElement('option');
        opt.value = tag.id;
        opt.textContent = tag.tagType ? `${tag.tagId} (${tag.tagType})` : tag.tagId;
        opt.className = 'bg-[#171D1D]';
        tagSelect.appendChild(opt);
      });

    } catch (e) {
      document.getElementById('invalid-token').classList.remove('hidden');
    }
  }

  loadCompany();

  // ── Tag select toggle ────────────────────────────────────────
  document.getElementById('serviceTag').addEventListener('change', function() {
    document.getElementById('tag-select-container').classList.toggle('hidden', !this.checked);
  });

  // ── Helpers ──────────────────────────────────────────────────

  // Create-first pattern: attempt POST, on RECORD_NOT_UNIQUE fetch the existing record.
  // This avoids needing public read access for dedup lookups.
  async function createOrFind(collection, createPayload, lookupFilter) {
    const createRes = await fetch(`${DIRECTUS_URL}/items/${collection}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(createPayload),
    });
    if (createRes.ok) return (await createRes.json()).data?.id;

    const err = await createRes.json();
    const isConflict = err?.errors?.some(e => e.extensions?.code === 'RECORD_NOT_UNIQUE');
    if (!isConflict) throw new Error(`Failed to create ${collection}: HTTP ${createRes.status}`);

    // Already exists — fetch by the unique field(s)
    const qs = Object.entries(lookupFilter)
      .map(([k, v]) => `filter[${k}][_eq]=${encodeURIComponent(v)}`)
      .join('&');
    const findRes = await fetch(`${DIRECTUS_URL}/items/${collection}?${qs}&fields=id&limit=1`);
    if (!findRes.ok) throw new Error(`Failed to look up existing ${collection}`);
    const existing = (await findRes.json()).data?.[0];
    if (!existing) throw new Error(`${collection} conflict but record not found`);
    return existing.id;
  }

  async function findOrCreateFlight(f) {
    // Dedup by qualified number + airports
    const qs = [
      `filter[flightNumber][_eq]=${encodeURIComponent(f.qualified)}`,
      f.depAirportId ? `filter[departureAirport][_eq]=${f.depAirportId}` : '',
      f.arrAirportId ? `filter[destinationAirport][_eq]=${f.arrAirportId}` : '',
      'fields=id', 'limit=1',
    ].filter(Boolean).join('&');
    const findRes = await fetch(`${DIRECTUS_URL}/items/flights?${qs}`);
    const found = (await findRes.json()).data?.[0];
    if (found) return found.id;

    // Look up airline FK
    const prefix = f.rawNumber.match(/^[A-Z]{2}/)?.[0];
    let airlineId = null;
    if (prefix) {
      const ar = await fetch(`${DIRECTUS_URL}/items/airlines?filter[iataCode][_eq]=${prefix}&fields=id&limit=1`);
      airlineId = (await ar.json()).data?.[0]?.id ?? null;
    }

    const body = {
      flightNumber: f.qualified,
      ...(f.depLocalDT ? { startDateTime: f.depLocalDT } : {}),
      ...(f.arrLocalDT ? { endDateTime: f.arrLocalDT } : {}),
      ...(f.depAirportId ? { departureAirport: f.depAirportId } : {}),
      ...(f.arrAirportId ? { destinationAirport: f.arrAirportId } : {}),
      ...(f.depTZ ? { startDisplayTimezone: f.depTZ } : {}),
      ...(f.arrTZ ? { endDisplayTimezone: f.arrTZ } : {}),
      ...(airlineId ? { airline: airlineId } : {}),
    };

    const createRes = await fetch(`${DIRECTUS_URL}/items/flights`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!createRes.ok) throw new Error(`Failed to create flight: HTTP ${createRes.status}`);
    return (await createRes.json()).data?.id;
  }

  // ── Form submission ──────────────────────────────────────────
  document.getElementById('booking-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const errorEl = document.getElementById('form-error');
    btn.disabled = true;
    btn.textContent = 'Submitting…';
    errorEl.classList.add('hidden');

    if (confirmedFlights.length === 0) {
      document.getElementById('flights-required').classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Submit Reservation Request';
      return;
    }

    const form = e.target;
    const email = form.email.value;
    const petName = form.petName.value;

    try {
      btn.textContent = 'Looking up customer…';
      const customerId = await createOrFind(
        'customers',
        {
          firstName: form.firstName.value,
          lastName: form.lastName.value,
          email,
          phoneNumber: form.phone.value,
        },
        { email }
      );

      btn.textContent = 'Looking up pet…';
      // Pets have no unique constraint on name+customer, so use read-first pattern
      const petFindQs = `filter[name][_eq]=${encodeURIComponent(petName)}&filter[customer][_eq]=${customerId}&fields=id&limit=1`;
      const petFindRes = await fetch(`${DIRECTUS_URL}/items/pets?${petFindQs}`);
      const existingPet = (await petFindRes.json()).data?.[0];
      let petId;
      if (existingPet) {
        petId = existingPet.id;
      } else {
        const petCreateRes = await fetch(`${DIRECTUS_URL}/items/pets`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: petName, type: form.petBreed.value, customer: customerId }),
        });
        if (!petCreateRes.ok) throw new Error(`Failed to create pet: HTTP ${petCreateRes.status}`);
        petId = (await petCreateRes.json()).data?.id;
      }

      btn.textContent = 'Checking reference…';
      const companyId = document.getElementById('company-id').value;
      const reference = form.companyReference.value.trim();
      const refCheck = await fetch(
        `${DIRECTUS_URL}/items/trips?filter[reference][_eq]=${encodeURIComponent(reference)}&fields=id&limit=1`
      );
      const refExists = (await refCheck.json()).data?.length > 0;
      if (refExists) {
        throw { userMessage: 'This booking reference has already been submitted. Please check your reference number or contact us if you believe this is an error.' };
      }

      btn.textContent = 'Processing flights…';
      const flightIds = [];
      const flightNumbers = [];
      for (const f of confirmedFlights) {
        const flightId = await findOrCreateFlight(f);
        flightIds.push(flightId);
        flightNumbers.push(f.qualified);
      }

      btn.textContent = 'Creating trip…';
      const payload = {
        petId,
        customerId,
        companyId,
        companyReference: reference,
        contactName: form.contactName.value,
        contactEmail: form.contactEmail.value,
        email,
        firstName: form.firstName.value,
        lastName: form.lastName.value,
        phone: form.phone.value,
        petName,
        petBreed: form.petBreed.value,
        servicesRequested: [
          form.serviceDevice.checked ? 'device' : null,
          form.serviceTag.checked ? 'tag' : null,
        ].filter(Boolean),
        tagId: form.serviceTag.checked && form.tagId.value ? Number(form.tagId.value) : null,
        notes: form.notes.value,
        flightIds,
        flightNumbers,
      };

      const res = await fetch(`${DIRECTUS_URL}/flows/trigger/e1a3f94d-7b89-40c3-89b6-325489c2172b`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      document.getElementById('booking-form').classList.add('hidden');
      document.getElementById('success-message').classList.remove('hidden');
    } catch (err) {
      errorEl.textContent = err?.userMessage ?? 'Something went wrong. Please try again or contact us directly.';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Submit Reservation Request';
    }
  });
</script>
