---
import type { SectionItem } from '../../../lib/directus';
import { fileUrl } from '../../../lib/directus';

interface Props { item: SectionItem }
const { item } = Astro.props;
const imgUrl = fileUrl(item.image);
---

<div class="bg-white/5 border border-white/10 rounded-xl overflow-hidden flex flex-col">
  {imgUrl && (
    <img src={imgUrl} alt={item.heading ?? ''} class="w-full h-48 object-cover" />
  )}
  <div class="p-6 flex flex-col flex-1">
    {item.heading && <h3 class="text-white font-bold text-lg mb-1">{item.heading}</h3>}
    {item.body && <p class="text-white/70 text-sm flex-1">{item.body}</p>}
    {item.link && (
      <a href={item.link} class="mt-4 text-[#ffc803] text-sm hover:underline">Learn more →</a>
    )}
  </div>
</div>
