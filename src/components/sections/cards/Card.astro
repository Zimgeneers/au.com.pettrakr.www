---
import type { SectionItem } from '../../../lib/directus';
import { fileUrl } from '../../../lib/directus';

interface Props { item: SectionItem; isDark?: boolean }
const { item, isDark = false } = Astro.props;
const imgUrl   = fileUrl(item.image);
const cardBg   = isDark ? 'bg-white/5 border-white/10' : 'bg-black/5 border-black/10';
---

<div class={`border rounded-xl overflow-hidden flex flex-col ${cardBg}`}>
  {imgUrl && (
    <img src={imgUrl} alt={item.heading ?? ''} class="w-full h-48 object-cover" />
  )}
  <div class="p-6 flex flex-col flex-1">
    {item.heading && <h3 class="text-current font-bold text-lg mb-1">{item.heading}</h3>}
    {item.body && <p class="text-current opacity-70 text-sm flex-1">{item.body}</p>}
    {item.link && (
      <a href={item.link} class="mt-4 text-[#ffc803] text-sm hover:underline">Learn more →</a>
    )}
  </div>
</div>
