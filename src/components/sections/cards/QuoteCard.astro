---
import type { SectionItem } from '../../../lib/directus';
import { fileUrl } from '../../../lib/directus';

interface Props { item: SectionItem; isDark?: boolean }
const { item, isDark = false } = Astro.props;
const avatarUrl = fileUrl(item.image);
const cardBg = isDark ? 'bg-white/5 border-white/10' : 'bg-black/5 border-black/10';
const divBorder = isDark ? 'border-white/10' : 'border-black/10';
---

<div class={`border rounded-xl p-6 flex flex-col gap-4 ${cardBg}`}>
  <p class="text-current opacity-80 text-base leading-relaxed flex-1">
    <span class="text-[#ffc803] text-2xl font-serif leading-none mr-1">"</span>{item.quote ?? item.body}<span class="text-[#ffc803] text-2xl font-serif leading-none ml-1">"</span>
  </p>
  <div class={`flex items-center gap-3 pt-2 border-t ${divBorder}`}>
    {avatarUrl && (
      <img src={avatarUrl} alt={item.author ?? ''} class="w-10 h-10 rounded-full object-cover flex-shrink-0" />
    )}
    {item.author && <p class="text-current font-bold text-sm">{item.author}</p>}
  </div>
</div>
