---
import { getSiteSettings } from '../lib/directus';

const settings = await getSiteSettings();
const year = new Date().getFullYear();
---

<footer class="bg-[#171D1D] text-white mt-auto">
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <!-- Social links -->
      <div class="flex items-center gap-4">
        {settings.facebook && (
          <a href={settings.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook"
            class="bg-white/10 hover:bg-white/20 rounded-full p-3 transition-colors">
            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        )}
        {settings.linkedin && (
          <a href={settings.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"
            class="bg-white/10 hover:bg-white/20 rounded-full p-3 transition-colors">
            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        )}
        {settings.contactEmail && (
          <a href={`mailto:${settings.contactEmail}`} aria-label="Email"
            class="bg-white/10 hover:bg-white/20 rounded-full p-3 transition-colors">
            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </a>
        )}
      </div>

      <!-- Copyright -->
      <p class="text-white/50 text-sm text-center">
        © Zimgeneers Pty Ltd 2021–{year} | All rights reserved.
      </p>
    </div>
  </div>
</footer>
